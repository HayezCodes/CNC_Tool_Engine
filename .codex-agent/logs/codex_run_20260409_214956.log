                "cutting_speed_band": "NORMAL",
                "doc_band": "MEDIUM",
                "finish_priority": "NORMAL",
                "hole_type": "BLIND",
            },
        )

        self.assertIn("right-hand spiral", recommendation["geometry_focus"].lower())

