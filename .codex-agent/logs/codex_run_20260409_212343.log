def compact_tokens(*tokens: str) -> str:
    cleaned = []
    seen = set()
    for token in tokens:
        value = " ".join((token or "").split()).strip()
        if not value:
            continue
        key = value.upper()
        if key in seen:
            continue
        seen.add(key)
        cleaned.append(value)
