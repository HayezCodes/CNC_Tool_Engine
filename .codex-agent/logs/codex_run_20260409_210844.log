diff --git a/grade_engine/family_advisor.py b/grade_engine/family_advisor.py
new file mode 100755
index 0000000000000000000000000000000000000000..4d336f8407b960dd3e0c5d0e93fa3b28a0dc9daa
--- /dev/null
+++ b/grade_engine/family_advisor.py
@@ -0,0 +1,217 @@
+from urllib.parse import quote_plus
+
+from .engine import resolve_grade_behavior
+from .resolver import SUPPLIER_SEARCH, compact_query_tokens, get_material_word
+
+FAMILY_LABELS = {
+    "TURNING_INSERT": "Turning Insert",
+    "GROOVING_INSERT": "Grooving Insert",
+    "THREADING_INSERT": "Threading Insert",
+    "DRILL": "Drill",
+    "ENDMILL": "End Mill",
+    "FACE_MILL": "Face Mill",
+    "TAP": "Tap",
+    "REAMER": "Reamer",
+}
+
+
+def _stability_label(input_data: dict) -> str:
+    unstable_flags = 0
+    if input_data.get("interrupted_cut") in {"LIGHT", "HEAVY"}:
+        unstable_flags += 1
+    if input_data.get("stickout") == "LONG":
+        unstable_flags += 1
+    if input_data.get("workholding") in {"AVERAGE", "POOR"}:
+        unstable_flags += 1
+    if unstable_flags >= 2:
+        return "unstable"
+    if unstable_flags == 1:
+        return "mixed"
+    return "stable"
+
+
+def _general_watch_items(input_data: dict) -> list[str]:
+    watch_items = []
+    if input_data.get("interrupted_cut") == "HEAVY":
+        watch_items.append("Interruption is high, so keep radial load and shock under control.")
+    if input_data.get("stickout") == "LONG":
+        watch_items.append("Long stickout raises chatter risk. Shorten projection or back off aggressiveness.")
+    if input_data.get("workholding") == "POOR":
+        watch_items.append("Weak workholding can make any recommendation fail early. Fix the setup first if possible.")
+    if input_data.get("cutting_speed_band") == "HIGH":
+        watch_items.append("High speed needs heat control. Do not outrun coolant, chip evacuation, or toolholding.")
+    return watch_items
+
+
+def _family_strategy(tool_family: str, input_data: dict, behavior: dict) -> dict:
+    material_word = get_material_word(input_data["material_group"])
+    zone = input_data["application_zone"]
+    stability = _stability_label(input_data)
+    coating = behavior["preferred_coating"]
+    wear = behavior["required_wear_resistance"]
+    toughness = behavior["required_toughness"]
+
+    if tool_family == "GROOVING_INSERT":
+        style = "rigid double-ended grooving insert" if stability != "stable" else "sharp single-ended grooving insert"
+        geometry = "neutral-to-strong edge prep" if toughness == "HIGH" else "freer-cutting groove geometry"
+        holder = "short-overhang blade or holder with maximum support"
+        search_focus = "grooving insert"
+        summary = f"Start with a {style} for {material_word} work and bias the edge toward {geometry}."
+        notes = [
+            "Keep groove depth and chip evacuation in view before chasing speed.",
+            "Use the narrowest insert that still leaves margin for the groove width you need.",
+        ]
+    elif tool_family == "THREADING_INSERT":
+        style = "laydown threading insert with a stable holder pocket"
+        geometry = "full-profile" if zone == "WEAR" else "partial-profile"
+        holder = "minimum overhang threading holder"
+        search_focus = "threading insert"
+        summary = f"Start with a {geometry} {style} and keep the holder as rigid as the thread access allows."
+        notes = [
+            "Threading fails fast when the setup is loose, so rigidity matters more than catalog optimism.",
+            "Bias toward sharper geometry only when the cut is stable and chip control is predictable.",
+        ]
+    elif tool_family == "DRILL":
+        if stability == "unstable" or toughness == "HIGH":
+            style = "indexable or tough solid-carbide drill"
+        elif wear == "HIGH":
+            style = "solid-carbide drill"
+        else:
+            style = "general-purpose carbide drill"
+        geometry = "135-140 degree point" if material_word in {"steel", "stainless", "super alloy", "hardened steel"} else "high-positive polished point"
+        holder = "through-coolant body if depth or chip packing becomes a problem"
+        search_focus = "drill"
+        summary = f"Start with a {style} in {coating} style with a {geometry} suited for {material_word}."
+        notes = [
+            "Drills need chip evacuation first. Pecking is a recovery tactic, not a substitute for the right drill.",
+            "If the cut is interrupted or wandering, reduce the tool's leverage before pushing speed.",
+        ]
+    elif tool_family == "ENDMILL":
+        style = "variable-helix carbide end mill" if stability == "stable" else "tough variable-pitch carbide end mill"
+        geometry = "sharper edge and lighter radial engagement" if wear == "HIGH" else "stronger core and controlled engagement"
+        holder = "shrink-fit, hydraulic, or a clean collet with minimal runout"
+        search_focus = "end mill"
+        summary = f"Start with a {style} and run it with {geometry} for this {material_word} condition."
+        notes = [
+            "Slotting is the fastest way to expose a weak toolpath. Keep engagement honest.",
+            "Runout will ruin finish and tool life before grade selection does.",
+        ]
+    elif tool_family == "FACE_MILL":
+        style = "high-positive face mill" if stability != "stable" else "45-degree lead face mill"
+        geometry = "positive cutting edges to keep force down" if toughness == "HIGH" else "wear-oriented inserts for longer edge life"
+        holder = "largest stable arbor or shell-mill mount available"
+        search_focus = "face mill"
+        summary = f"Start with a {style} and keep the insert package biased toward {geometry}."
+        notes = [
+            "Face mills expose setup issues quickly. Watch spindle pull, arbor condition, and insert seating.",
+            "If the machine is light, lead angle and positive rake matter more than brute insert size.",
+        ]
+    elif tool_family == "TAP":
+        style = "premium HSS-E or carbide tap"
+        geometry = "form tap if the material is ductile and the hole allows it" if input_data["material_group"] in {"P", "N"} else "cut tap with reliable flute evacuation"
+        holder = "length-compensating or rigid synchronized tap holder"
+        search_focus = "tap"
+        summary = f"Start with a {style} and choose a thread-form strategy that matches chip evacuation and machine synchronization."
+        notes = [
+            "Tap failures usually come from hole prep, chip packing, or synchronization errors before they come from tap brand.",
+            "If the thread quality matters, verify the drill size and percent thread before changing tap geometry.",
+        ]
+    elif tool_family == "REAMER":
+        style = "carbide reamer" if wear == "HIGH" else "cobalt or carbide reamer"
+        geometry = "tight-margin finishing geometry"
+        holder = "floating or well-aligned holder to protect size"
+        search_focus = "reamer"
+        summary = f"Start with a {style} built for {geometry} and keep alignment under control."
+        notes = [
+            "A reamer only follows the hole it is given. Straightness and stock allowance matter more than pushing feed.",
+            "If size is drifting, inspect the pre-drill and holder alignment before changing the reamer.",
+        ]
+    else:
+        style = "turning insert package"
+        geometry = behavior["geometry_hint"]["geometry"]
+        holder = "rigid turning holder with clean seating"
+        search_focus = "turning insert"
+        summary = behavior["recommendation_summary"]
+        notes = [
+            "Insert shape, chipbreaker, and grade all need to agree with the stability of the cut.",
+            "When the setup is weak, protecting the edge usually beats chasing wear life.",
+        ]
+
+    return {
+        "style": style,
+        "geometry": geometry,
+        "holder": holder,
+        "search_focus": search_focus,
+        "summary": summary,
+        "notes": notes,
+    }
+
+
+def _build_family_supplier_matches(tool_family: str, input_data: dict, behavior: dict, strategy: dict) -> dict:
+    family_name = FAMILY_LABELS[tool_family].lower()
+    material_word = get_material_word(input_data["material_group"])
+    primary_query = compact_query_tokens(
+        strategy["style"],
+        behavior["preferred_coating"],
+        strategy["geometry"],
+        material_word,
+        strategy["search_focus"],
+    )
+    fallback_query = compact_query_tokens(
+        strategy["search_focus"],
+        material_word,
+        "general purpose",
+        family_name,
+    )
+
+    output = {}
+    for supplier, template in SUPPLIER_SEARCH.items():
+        output[supplier] = {
+            "recommended_item": strategy["style"],
+            "fallback_item": f"General-purpose {family_name}",
+            "description": f"{strategy['summary']} Holder focus: {strategy['holder']}.",
+            "search_query": primary_query,
+            "fallback_query": fallback_query,
+            "links": {
+                "Search": template.format(query=quote_plus(primary_query)),
+                "Fallback Search": template.format(query=quote_plus(fallback_query)),
+            },
+        }
+    return output
+
+
+def resolve_tool_family(tool_family: str, input_data: dict) -> dict:
+    behavior = resolve_grade_behavior(input_data)
+    if tool_family == "TURNING_INSERT":
+        return {
+            "tool_family": tool_family,
+            "family_label": FAMILY_LABELS[tool_family],
+            "behavior": behavior,
+            "summary": behavior["recommendation_summary"],
+            "watch_items": behavior["risk_flags"],
+            "shop_notes": [],
+            "supplier_matches": {},
+            "starter_tool": {},
+        }
+
+    strategy = _family_strategy(tool_family, input_data, behavior)
+    watch_items = _general_watch_items(input_data)
+    if input_data["material_group"] == "M":
+        watch_items.append("Stainless rewards consistent chip load. Avoid rubbing or dwell.")
+    if input_data["material_group"] == "N":
+        watch_items.append("Non-ferrous work can weld to the edge if chip evacuation and lubrication are poor.")
+
+    return {
+        "tool_family": tool_family,
+        "family_label": FAMILY_LABELS[tool_family],
+        "behavior": behavior,
+        "summary": strategy["summary"],
+        "watch_items": watch_items,
+        "shop_notes": strategy["notes"],
+        "starter_tool": {
+            "style": strategy["style"],
+            "geometry": strategy["geometry"],
+            "holder": strategy["holder"],
+        },
+        "supplier_matches": _build_family_supplier_matches(tool_family, input_data, behavior, strategy),
+    }
